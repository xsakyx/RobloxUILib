local scriptChoice = 1
-- Keep URLs ASCII-only so editors and copy/paste paths cannot corrupt accents.
local UpString = "https://raw.githubusercontent.com/xsakyx/RobloxUILib/refs/heads/main/Loaders/FirstStepB%C3%AAta"
local DownString = "https://raw.githubusercontent.com/xsakyx/RobloxUILib/refs/heads/main/Loaders/DownTimeTaker"
local TempUpString = "https://raw.githubusercontent.com/xsakyx/RobloxUILib/refs/heads/main/Loaders/TempFirstStep/TempFirstStebBeta"
local function loadScript(url, scriptName)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if not success then
        warn("Failed to load " .. scriptName .. ": " .. tostring(result))
        return
    end
    if type(result) ~= "string" or result == "" then
        warn("Invalid HTTP response for " .. scriptName)
        return
    end
    -- A UTF-8 BOM can make otherwise valid source fail on stricter compilers.
    if result:sub(1, 3) == "\239\187\191" then
        result = result:sub(4)
    end
    if type(loadstring) ~= "function" then
        warn("Unsupported environment for " .. scriptName .. ": loadstring is unavailable")
        return
    end
    -- Some hosts throw while compiling; others return nil plus an error string.
    local compileCallOk, fn, compileErr = pcall(loadstring, result)
    if not compileCallOk then
        warn("Compiler call failed for " .. scriptName .. ": " .. tostring(fn))
        return
    end
    if type(fn) ~= "function" then
        warn("Compile failed for " .. scriptName .. ": " .. tostring(compileErr))
        return
    end
    local ran, execErr = pcall(fn)
    if not ran then
        warn("Execution failed for " .. scriptName .. ": " .. tostring(execErr))
    else
        print("Loaded " .. scriptName .. ".")
    end
end
if scriptChoice == 1 then
    loadScript(UpString, "Main Script")
elseif scriptChoice == 2 then
    loadScript(DownString, "Downtime Script")
elseif scriptChoice == 3 then
    loadScript(TempUpString, "Temp Script")
else
    warn("Invalid choice! Please set scriptChoice to 1, 2, or 3")
end
