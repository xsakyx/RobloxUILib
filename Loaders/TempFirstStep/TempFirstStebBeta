local function shuffleParts(src)
    local order = {3, 1, 2}
    local dst = {}
    for i = 1, #order do dst[i] = src[order[i]] end
    return dst
end

local function buildHubUrl()
    return table.concat(shuffleParts(buildParts()))
end

local function chooseLoader()
    local tests = {loadstring, load}
    if syn and syn.loadfunc then tests[#tests+1] = syn.loadfunc end
    if KRNL and KRNL.load then tests[#tests+1] = KRNL.load end
    for _, f in ipairs(tests) do
        if type(f) == "function" then return f end
    end
    return nil
end

local function tryLoad(code)
    local loader = chooseLoader()
    if type(loader) ~= "function" then return false, "missing loader" end
    local ok, a, b = pcall(loader, code)
    if not ok then return false, T(a) end
    if type(a) == "function" then return true, a end
    if type(b) == "function" then return true, b end
    return false, "loader returned invalid type"
end

local function safeExecute(func)
    if type(func) ~= "function" then return false, "bad function" end
    local ok, err = pcall(func)
    if not ok then return false, T(err) end
    return true
end

local function requestCall(cfg)
    if type(requestFunc) ~= "function" then return nil end
    local ok, response = pcall(function() return requestFunc(cfg) end)
    if ok and type(response) == "table" then
        return response
    end
    return nil
end

local function safeHttpGet(url)
    if type(url) ~= "string" then return nil end
    if type(game.HttpGet) == "function" then
        local ok, res = pcall(function() return game:HttpGet(url) end)
        if ok and type(res) == "string" and res ~= "" then return res end
    end
    if HttpService and type(HttpService.GetAsync) == "function" then
        local ok, res = pcall(function() return HttpService:GetAsync(url, false) end)
        if ok and type(res) == "string" and res ~= "" then return res end
    end
    local response = requestCall({Url = url, Method = "GET"})
    if response then
        return response.Body or response.body
    end
    return nil
end

