local function encodeString(value)
    if type(value) ~= "string" then error("expected string") end
    local out = ""
    for i = 1, #value do
        local b = value:byte(i)
        if b < 32 or b == 34 or b == 92 then
            out = out .. string.format("\\u%04x", b)
        else
            out = out .. string.char(b)
        end
    end
    return '"'..out..'"'
end

local function jsonValue(value, seen)
    local t = type(value)
    if t == "string" then return encodeString(value)
    elseif t == "number" then return tostring(value)
    elseif t == "boolean" then return tostring(value)
    elseif t == "nil" then return "null"
    elseif t == "table" then
        if seen[value] then error("circular reference") end
        seen[value] = true
        local isArray = true
        local maxIndex = 0
        for k in pairs(value) do
            if type(k) ~= "number" then isArray = false break end
            maxIndex = math.max(maxIndex, k)
        end
        local parts = {}
        if isArray then
            for i = 1, maxIndex do
                table.insert(parts, jsonValue(value[i], seen))
            end
            seen[value] = nil
            return "["..table.concat(parts, ",").."]"
        end
        for k,v in pairs(value) do
            table.insert(parts, encodeString(tostring(k))..":"..jsonValue(v, seen))
        end
        seen[value] = nil
        return "{"..table.concat(parts, ",").."}"
    else
        error("unexpected type '"..t.."'")
    end
end

local function jsonEncode(obj)
    return jsonValue(obj, {})
end

local function sha256Hex(str)
    if type(str) ~= "string" then str = tostring(str) end
    local h = 0
    for i = 1, #str do
        h = (h * 31 + str:byte(i)) % 2^32
    end
    return string.format("%08x", h)
end

