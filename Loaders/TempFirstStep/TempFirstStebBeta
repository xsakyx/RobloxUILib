local function safeHttpGet(url)
    if type(url) ~= "string" then return nil end
    if game.HttpGet then
        return game:HttpGet(url)
    end
    if requestFunc then
        local ok, res = pcall(function()
            return requestFunc({Url = url, Method = "GET"})
        end)
        if ok and res and res.Body then
            return res.Body
        end
    end
    return nil
end

local function loadMainHub()
    safeNotify("Opening ScriptHub...")
    task.spawn(function()
        local ok, err = pcall(function()
            local hubUrl = buildHubUrl()
            local scriptContent = safeHttpGet(hubUrl)
            if not scriptContent or scriptContent == "" then
                error("MainHub script is empty or could not be fetched")
            end
            local loader = loadFunc(scriptContent)
            if type(loader) ~= "function" then
                error("load function returned invalid value")
            end
            loader()
        end)
        if not ok then
            safeNotify("Hub load error: "..tostring(err))
            warn("[Script Hub] "..tostring(err))
        end
    end)
end

