local function loadMainHub()
    errNotify("Opening ScriptHub...")
    task.spawn(function()
        local ok, err = pcall(function()
            local url = buildHubUrl()
            local content = safeHttpGet(url)
            local loader
            if content and content ~= "" then
                local loaded, maybeLoader = tryLoad(content)
                if loaded then
                    loader = maybeLoader
                end
            end
            if not loader then
                local fallback = fallbackHubScript()
                local loaded, maybeLoader = tryLoad(fallback)
                if not loaded then error("fallback loader failed: " .. T(maybeLoader)) end
                loader = maybeLoader
            end
            local ran, rerr = safeExecute(loader)
            if not ran then error(rerr) end
        end)
        if not ok then
            errNotify("Hub load error: " .. T(err))
            warn("[Script Hub] " .. T(err))
        end
    end)
end

