local function simpleEncode(value)
    if type(value) ~= "string" then error("expected string") end
    local out = {}
    for i = 1, #value do
        local b = value:byte(i)
        if b < 32 or b == 34 or b == 92 then
            out[#out+1] = string.format("\\u%04x", b)
        else
            out[#out+1] = chr(b)
        end
    end
    return '"' .. table.concat(out) .. '"'
end

local function jsonValue(value, seen)
    local vtype = type(value)
    if vtype == "string" then return simpleEncode(value)
    elseif vtype == "number" then return T(value)
    elseif vtype == "boolean" then return T(value)
    elseif vtype == "nil" then return "null"
    elseif vtype == "table" then
        if seen[value] then error("circular reference") end
        seen[value] = true
        local isArray = true
        local maxIndex = 0
        for k in pairs(value) do
            if type(k) ~= "number" then isArray = false break end
            if k > maxIndex then maxIndex = k end
        end
        local parts = {}
        if isArray then
            for i = 1, maxIndex do
                parts[#parts+1] = jsonValue(value[i], seen)
            end
            seen[value] = nil
            return "[" .. table.concat(parts, ",") .. "]"
        end
        for k,v in pairs(value) do
            parts[#parts+1] = simpleEncode(T(k)) .. ":" .. jsonValue(v, seen)
        end
        seen[value] = nil
        return "{" .. table.concat(parts, ",") .. "}"
    else
        error("unexpected type '" .. vtype .. "'")
    end
end

local function jsonEncode(obj)
    return jsonValue(obj, {})
end

local function buildParts()
