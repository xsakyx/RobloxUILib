--// LIVE LABEL UPDATES
--------------------------------------------------------------------------------
task.spawn(function()
    while ScriptEnabled do
        task.wait(0.3)
        safeCall(function()
            -- Record tab
            if Recording.IsRecording then
                RecordStatusLabel:SetText("Status: 🔴 RECORDING")
                FramesLabel:SetText("Frames: " .. #Recording.Frames)
                RecordFPSLabel:SetText("Recording FPS: " .. math.floor(Recording.CurrentFPS))
                if Recording.PointB and updateCharacter() then
                    local d = math.floor((Recording.PointB - humanoidRootPart.Position).Magnitude)
                    DistToB:SetText("Distance to B: " .. d .. " studs")
                end
            else
                RecordStatusLabel:SetText("Status: Idle")
                FramesLabel:SetText("Frames: " .. Recording.TotalFrames)
                DistToB:SetText("Distance to B: --")
                if Recording.TotalFrames > 0 then
                    RecordFPSLabel:SetText("Recorded @ " .. math.floor(Recording.RecordedFPS) .. " FPS")
                else
                    RecordFPSLabel:SetText("Recording FPS: N/A")
                end
            end

            -- Replay tab
            if Recording.IsReplaying then
                local progress = 0
                if Recording.TotalFrames > 0 then
                    progress = (Recording.CurrentFrameIndex / Recording.TotalFrames) * 100
                end
                local status = "Status: ▶️ REPLAYING"
                if ReplayLoopEnabled then
                    status = status .. " (Loop #" .. ReplayLoopIteration .. ")"
                end
                if PlaybackSpeed ~= 1 then
                    status = status .. " [" .. PlaybackSpeed .. "x]"
                end
                ReplayStatusLabel:SetText(status)
                ProgressLabel:SetText("Progress: " .. math.floor(progress) .. "% (" .. Recording.CurrentFrameIndex .. "/" .. Recording.TotalFrames .. ")")

                if updateCharacter() and Recording.Frames[Recording.CurrentFrameIndex] then
                    local err = (Recording.Frames[Recording.CurrentFrameIndex].Position - humanoidRootPart.Position).Magnitude
                    DriftLabel:SetText("Drift: " .. string.format("%.1f", err) .. " studs")
                    if err < 2 then
                        DriftStatusLabel:SetText("Drift: ✓ Perfect")
                    elseif err < 5 then
                        DriftStatusLabel:SetText("Drift: ⚠️ Minor")
                    elseif err < 10 then
                        DriftStatusLabel:SetText("Drift: ⚠️ Medium")
                    else
                        DriftStatusLabel:SetText("Drift: 🚨 Critical")
                    end
                end
            elseif ReplayLoopEnabled then
                ReplayStatusLabel:SetText("Status: ⏳ Resetting...")
                ProgressLabel:SetText("Progress: 0%")
                DriftLabel:SetText("Drift: 0 studs")
                DriftStatusLabel:SetText("Drift: --")
            else
                ReplayStatusLabel:SetText("Status: Idle")
                ProgressLabel:SetText("Progress: 0%")
                DriftLabel:SetText("Drift: 0 studs")
                DriftStatusLabel:SetText("Drift: --")
            end
            LoopCountLabel:SetText("Loops: " .. ReplayLoopIteration)

            -- Stats tab
            StatFrames:SetText("Total Frames: " .. Recording.TotalFrames)
            StatDuration:SetText("Duration: " .. formatTime(Recording.RecordingDuration))
            StatCurrentFPS:SetText("Current FPS: " .. math.floor(Recording.CurrentFPS))
            if Recording.TotalFrames > 0 then
                StatFPS:SetText("Recorded FPS: " .. math.floor(Recording.RecordedFPS))
            else
                StatFPS:SetText("Recorded FPS: N/A")
            end
            if Recording.PointA and Recording.PointB then
                StatDistance:SetText("Distance A->B: " .. math.floor((Recording.PointB - Recording.PointA).Magnitude) .. " studs")
            else
                StatDistance:SetText("Distance A->B: N/A")
            end
        end, "labelUpdate")
    end
end)

