    Flag = "ReplayLoop",
    Callback = function(value)
        if value then
            if #Recording.Frames == 0 then
                Library:Notify({Title = "Error", Content = "No recording to replay!", Emoji = "❌", Duration = 3})
                return
            end
            if Recording.IsRecording then
                Library:Notify({Title = "Error", Content = "Stop recording first!", Emoji = "❌", Duration = 3})
                return
            end
            ReplayLoopEnabled = true
            ReplayLoopIteration = 0
            startReplayLoop()
            Library:Notify({Title = "Loop Started", Content = "Looping at " .. PlaybackSpeed .. "x", Emoji = "🔁", Duration = 3})
        else
            stopReplayLoop()
