-- =====================================================
---------------------------------------------------------
local FlyModule = {}
FlyModule.Flying = false
FlyModule.Speed = 50
FlyModule.BoostMultiplier = 2
FlyModule.Connection = nil
FlyModule.BV = nil
FlyModule.BAV = nil

function FlyModule.Start()
    if FlyModule.Flying then return end
    local char, hum, root = GetCharacter()
    if not char then Notify("Fly", "No character", "❌", 2); return end

    FlyModule.Flying = true
    hum.PlatformStand = true

    FlyModule.BV = Instance.new("BodyVelocity")
    FlyModule.BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    FlyModule.BV.Velocity = Vector3.zero
    FlyModule.BV.Parent = root

    FlyModule.BAV = Instance.new("BodyAngularVelocity")
    FlyModule.BAV.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    FlyModule.BAV.AngularVelocity = Vector3.zero
    FlyModule.BAV.Parent = root

    FlyModule.Connection = RunService.RenderStepped:Connect(function()
        local cam = workspace.CurrentCamera
        local mv = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv = mv + Vector3.new(0, 0, -1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv = mv + Vector3.new(0, 0, 1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv = mv + Vector3.new(-1, 0, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv = mv + Vector3.new(1, 0, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv = mv + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then mv = mv + Vector3.new(0, -1, 0) end

        local speed = FlyModule.Speed
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            speed = speed * FlyModule.BoostMultiplier
        end

        if mv.Magnitude > 0 then
            FlyModule.BV.Velocity = cam.CFrame:VectorToWorldSpace(mv.Unit) * speed
        else
            FlyModule.BV.Velocity = Vector3.zero
        end
        FlyModule.BAV.AngularVelocity = Vector3.zero
    end)

    Notify("Fly", "ON | Shift=boost | E=toggle", "✈️", 2)
end

function FlyModule.Stop()
    FlyModule.Flying = false
    if FlyModule.BV then FlyModule.BV:Destroy(); FlyModule.BV = nil end
    if FlyModule.BAV then FlyModule.BAV:Destroy(); FlyModule.BAV = nil end
    if FlyModule.Connection then FlyModule.Connection:Disconnect(); FlyModule.Connection = nil end
    local _, hum, _ = GetCharacter()
    if hum then hum.PlatformStand = false end
    Notify("Fly", "OFF", "✈️", 2)
end

function FlyModule.Toggle()
    if FlyModule.Flying then FlyModule.Stop() else FlyModule.Start() end
end

