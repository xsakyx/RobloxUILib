function BangModule.Start(playerName)
    if BangModule.Active then BangModule.Stop() end

    local target = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (p.Name == playerName or string.lower(p.Name):find(string.lower(playerName))) then
            target = p
            break
        end
    end
    if not target then Notify("Bang", "Player not found", "❌", 2); return end
    if not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
        Notify("Bang", target.Name .. " has no character", "❌", 2); return
    end

    local char, hum, root = GetCharacter()
    if not char then return end

    BangModule.Active = true
    BangModule.Target = target

    -- Play thrust animation
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://148840371"
    pcall(function()
        BangModule.AnimTrack = hum:LoadAnimation(anim)
        BangModule.AnimTrack.Looped = true
        BangModule.AnimTrack:Play()
    end)

    -- Disable collision
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end

    hum.PlatformStand = true

    BangModule.BP = Instance.new("BodyPosition")
    BangModule.BP.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    BangModule.BP.P = 30000
    BangModule.BP.D = 1000
    BangModule.BP.Parent = root

    BangModule.BG = Instance.new("BodyGyro")
    BangModule.BG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    BangModule.BG.P = 30000
    BangModule.BG.Parent = root

    BangModule.Connection = RunService.Heartbeat:Connect(function()
        if not BangModule.Active or not BangModule.Target then return end
        local tp = BangModule.Target
        if not tp.Parent or not tp.Character or not tp.Character:FindFirstChild("HumanoidRootPart") then
            BangModule.Stop()
            return
        end

        local tRoot = tp.Character.HumanoidRootPart
        local offset = tRoot.CFrame.LookVector * 1.2
        BangModule.BP.Position = tRoot.Position + offset
        BangModule.BG.CFrame = CFrame.new(tRoot.Position + offset, tRoot.Position)

        -- Keep collision off
        local c = LocalPlayer.Character
        if c then
            for _, p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end)

    Notify("Bang", "Targeting " .. target.Name, "💀", 3)
end

function BangModule.Stop()
    BangModule.Active = false
    BangModule.Target = nil
    if BangModule.Connection then BangModule.Connection:Disconnect(); BangModule.Connection = nil end
    if BangModule.AnimTrack then pcall(function() BangModule.AnimTrack:Stop() end); BangModule.AnimTrack = nil end
    if BangModule.BP then BangModule.BP:Destroy(); BangModule.BP = nil end
    if BangModule.BG then BangModule.BG:Destroy(); BangModule.BG = nil end

    local _, hum, _ = GetCharacter()
    if hum then hum.PlatformStand = false end
    local char = LocalPlayer.Character
    if char then
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                p.CanCollide = true
            end
        end
    end

    Notify("Bang", "Stopped", "💀", 2)
end

