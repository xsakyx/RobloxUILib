-- =====================================================
---------------------------------------------------------
SafeConnect(UserInputService.InputBegan, function(input, gpe)
    if gpe then return end

    if input.KeyCode == Enum.KeyCode.E then
        FlyModule.Toggle()
    elseif input.KeyCode == Enum.KeyCode.G then
        NoclipModule.Toggle()
    end
end)

