-- Auto-refresh player lists when players join/leave
---------------------------------------------------------
SafeConnect(Players.PlayerAdded, function()
    task.wait(1)
    pcall(function()
        local names = GetPlayerNames()
        tpDropdown:Refresh(names)
        interactDropdown:Refresh(names)
        bangDropdown:Refresh(names)
    end)
end)

SafeConnect(Players.PlayerRemoving, function()
    task.wait(0.5)
    pcall(function()
        local names = GetPlayerNames()
        tpDropdown:Refresh(names)
        interactDropdown:Refresh(names)
        bangDropdown:Refresh(names)
    end)
end)

