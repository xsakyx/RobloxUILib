---------------------------------------------------------
local InvisModule = {}
InvisModule.Active = false
InvisModule.SavedParts = {} -- {part = originalTransparency}
InvisModule.SavedDecals = {} -- {decal = {prop, originalVal}}
InvisModule.SavedClothing = {} -- {clothing = originalParent}
InvisModule.MeshTextures = {} -- {mesh = originalTextureId}

function InvisModule.MakeInvisible()
    if InvisModule.Active then return end
    local char = LocalPlayer.Character
    if not char then return end

    InvisModule.Active = true
    InvisModule.SavedParts = {}
    InvisModule.SavedDecals = {}
    InvisModule.SavedClothing = {}
    InvisModule.MeshTextures = {}

    -- Hide body parts
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            InvisModule.SavedParts[part] = part.Transparency
            part.Transparency = 1
        end
        if part:IsA("Decal") or part:IsA("Texture") then
            InvisModule.SavedDecals[part] = part.Transparency
            part.Transparency = 1
        end
        if part:IsA("SurfaceGui") then
            InvisModule.SavedDecals[part] = part.Enabled
            part.Enabled = false
        end
        if part:IsA("SpecialMesh") then
            InvisModule.MeshTextures[part] = part.TextureId
            part.TextureId = ""
        end
    end

    -- Hide accessories
    for _, acc in ipairs(char:GetChildren()) do
        if acc:IsA("Accessory") or acc:IsA("Hat") then
            local handle = acc:FindFirstChild("Handle")
            if handle then
                InvisModule.SavedParts[handle] = handle.Transparency
                handle.Transparency = 1
                for _, child in ipairs(handle:GetDescendants()) do
                    if child:IsA("SpecialMesh") then
                        InvisModule.MeshTextures[child] = child.TextureId
                        child.TextureId = ""
                    end
                end
            end
        end
    end

    -- Store clothing in ReplicatedStorage (safer than nil parent)
    for _, item in ipairs(char:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            InvisModule.SavedClothing[item] = char
            item.Parent = ReplicatedStorage
        end
    end

    Notify("Invisibility", "ON - You are invisible (client-side)", "👻", 3)
end

function InvisModule.MakeVisible()
    if not InvisModule.Active then return end
    InvisModule.Active = false

    -- Restore parts
    for part, orig in pairs(InvisModule.SavedParts) do
        if part and part.Parent then part.Transparency = orig end
    end

    -- Restore decals/guis
    for decal, orig in pairs(InvisModule.SavedDecals) do
        if decal and decal.Parent then
            if decal:IsA("Decal") or decal:IsA("Texture") then
                decal.Transparency = orig
            elseif decal:IsA("SurfaceGui") then
                decal.Enabled = orig
            end
        end
    end

    -- Restore mesh textures
    for mesh, texId in pairs(InvisModule.MeshTextures) do
        if mesh and mesh.Parent then mesh.TextureId = texId end
    end

    -- Restore clothing
    for clothing, parent in pairs(InvisModule.SavedClothing) do
        if clothing then
            pcall(function() clothing.Parent = parent end)
        end
    end

    InvisModule.SavedParts = {}
    InvisModule.SavedDecals = {}
    InvisModule.SavedClothing = {}
    InvisModule.MeshTextures = {}

    Notify("Invisibility", "OFF - You are visible again", "👻", 2)
end

function InvisModule.Toggle()
    if InvisModule.Active then InvisModule.MakeVisible() else InvisModule.MakeInvisible() end
end

