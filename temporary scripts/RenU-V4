local AimbotModule = {}
AimbotModule.Enabled = false
AimbotModule.TargetPlayer = nil
AimbotModule.FOVRadius = 120
AimbotModule.Connection = nil
AimbotModule.FOVCircle = nil
AimbotModule.KeyConnection = nil
AimbotModule.AutoLock = true
AimbotModule.Smoothing = 0.15
AimbotModule.PredictionStrength = 0.12
AimbotModule.AimPart = "Head"
AimbotModule.ShowFOV = true
AimbotModule.FOVColor = Color3.fromRGB(255, 0, 0)
AimbotModule.FOVFilled = false
AimbotModule.FOVThickness = 1
AimbotModule.WallCheck = true

function AimbotModule.CreateFOVCircle()
    if AimbotModule.FOVCircle then
        pcall(function() AimbotModule.FOVCircle:Remove() end)
    end
    AimbotModule.FOVCircle = Drawing.new("Circle")
    AimbotModule.FOVCircle.Color = AimbotModule.FOVColor
    AimbotModule.FOVCircle.Thickness = AimbotModule.FOVThickness
    AimbotModule.FOVCircle.NumSides = 64
    AimbotModule.FOVCircle.Radius = AimbotModule.FOVRadius
    AimbotModule.FOVCircle.Filled = AimbotModule.FOVFilled
    AimbotModule.FOVCircle.Transparency = 0.7
    AimbotModule.FOVCircle.Visible = AimbotModule.ShowFOV and AimbotModule.Enabled
    AimbotModule.FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

function AimbotModule.IsPlayerValid(player)
    if not player or player == LocalPlayer then return false end
    if not player.Character or not player.Character.Parent then return false end
    if not player.Character:FindFirstChild(AimbotModule.AimPart) then return false end
    if not player.Character:FindFirstChild("HumanoidRootPart") then return false end
    local hum = player.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return true
end

function AimbotModule.GetClosestPlayerInFOV()
    local closest, shortest = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if AimbotModule.IsPlayerValid(player) then
            local part = player.Character:FindFirstChild(AimbotModule.AimPart)
            local sp, onScreen = Camera:WorldToViewportPoint(part.Position)

            if onScreen and sp.Z > 0 then
                local pos = Vector2.new(sp.X, sp.Y)
                local dist = (center - pos).Magnitude

                if dist <= AimbotModule.FOVRadius and dist < shortest then
                    local valid = true
                    if AimbotModule.WallCheck and LocalPlayer.Character then
                        local params = RaycastParams.new()
                        params.FilterType = Enum.RaycastFilterType.Blacklist
                        params.FilterDescendantsInstances = {LocalPlayer.Character}
                        local dir = (part.Position - Camera.CFrame.Position)
                        local result = workspace:Raycast(Camera.CFrame.Position, dir.Unit * dir.Magnitude, params)
                        if result and not result.Instance:IsDescendantOf(player.Character) then
                            valid = false
                        end
                    end
                    if valid then
                        closest = player
                        shortest = dist
                    end
                end
            end
        end
    end
    return closest
end

function AimbotModule.PredictPosition(part)
    local vel = Vector3.zero
    local hrp = part.Parent:FindFirstChild("HumanoidRootPart")
    if hrp then
        vel = hrp.AssemblyLinearVelocity or hrp.Velocity or Vector3.zero
    end
    local dist = (part.Position - Camera.CFrame.Position).Magnitude
    local ttt = dist / 1000
    return part.Position + (vel * ttt * AimbotModule.PredictionStrength)
end

function AimbotModule.LockOnTarget()
    if not AimbotModule.TargetPlayer or not AimbotModule.IsPlayerValid(AimbotModule.TargetPlayer) then
        AimbotModule.TargetPlayer = nil
        return
    end

    local part = AimbotModule.TargetPlayer.Character:FindFirstChild(AimbotModule.AimPart)
    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen or sp.Z <= 0 then
        AimbotModule.TargetPlayer = nil
        return
    end

    local predicted = AimbotModule.PredictPosition(part)
    local targetCF = CFrame.lookAt(Camera.CFrame.Position, predicted)

    local screenPos = Vector2.new(sp.X, sp.Y)
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local screenDist = (center - screenPos).Magnitude

    local smooth = AimbotModule.Smoothing * math.clamp(screenDist / AimbotModule.FOVRadius, 0.3, 1.2)
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, smooth)

    if screenDist < 5 then
        Camera.CFrame = targetCF
    end
end

function AimbotModule.Enable()
    if AimbotModule.Enabled then return end
    AimbotModule.Enabled = true
    AimbotModule.CreateFOVCircle()

    AimbotModule.Connection = RunService.RenderStepped:Connect(function()
        if AimbotModule.FOVCircle then
            AimbotModule.FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            AimbotModule.FOVCircle.Radius = AimbotModule.FOVRadius
            AimbotModule.FOVCircle.Visible = AimbotModule.ShowFOV and AimbotModule.Enabled
            AimbotModule.FOVCircle.Color = AimbotModule.FOVColor
            AimbotModule.FOVCircle.Filled = AimbotModule.FOVFilled
            AimbotModule.FOVCircle.Thickness = AimbotModule.FOVThickness
        end

        if AimbotModule.AutoLock then
            if not AimbotModule.TargetPlayer or not AimbotModule.IsPlayerValid(AimbotModule.TargetPlayer) then
                AimbotModule.TargetPlayer = AimbotModule.GetClosestPlayerInFOV()
            else
                local part = AimbotModule.TargetPlayer.Character:FindFirstChild(AimbotModule.AimPart)
                local sp, on = Camera:WorldToViewportPoint(part.Position)
                if on and sp.Z > 0 then
                    local pos = Vector2.new(sp.X, sp.Y)
                    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local dist = (center - pos).Magnitude
                    if dist > AimbotModule.FOVRadius * 1.1 then
                        AimbotModule.TargetPlayer = AimbotModule.GetClosestPlayerInFOV()
                    end
                else
                    AimbotModule.TargetPlayer = AimbotModule.GetClosestPlayerInFOV()
                end
            end
        end

        if AimbotModule.TargetPlayer then
            AimbotModule.LockOnTarget()
        end
    end)

    AimbotModule.KeyConnection = SafeConnect(UserInputService.InputBegan, function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.X then
            if AimbotModule.TargetPlayer then
                AimbotModule.TargetPlayer = nil
                AimbotModule.AutoLock = false
                Notify("Aimbot", "Target unlocked (3s pause)", "🎯", 2)
                task.delay(3, function() AimbotModule.AutoLock = true end)
            else
                local t = AimbotModule.GetClosestPlayerInFOV()
                if t then
                    AimbotModule.TargetPlayer = t
                    Notify("Aimbot", "Locked: " .. t.Name, "🎯", 2)
                else
                    Notify("Aimbot", "No targets in FOV", "🎯", 1)
                end
            end
        end
    end)

    Notify("Aimbot", "Enabled | X = manual lock", "🎯", 3)
end

function AimbotModule.Disable()
    if not AimbotModule.Enabled then return end
    AimbotModule.Enabled = false
    AimbotModule.TargetPlayer = nil
    AimbotModule.AutoLock = true
    if AimbotModule.Connection then AimbotModule.Connection:Disconnect(); AimbotModule.Connection = nil end
    if AimbotModule.KeyConnection then AimbotModule.KeyConnection:Disconnect(); AimbotModule.KeyConnection = nil end
    if AimbotModule.FOVCircle then pcall(function() AimbotModule.FOVCircle:Remove() end); AimbotModule.FOVCircle = nil end
    Notify("Aimbot", "Disabled", "🎯", 2)
end

