-- MODULE: FOLLOW PLAYER (FIXED)
-- =====================================================
---------------------------------------------------------
local FollowModule = {}
FollowModule.Active = false
FollowModule.Target = nil
FollowModule.Mode = "Follow"
FollowModule.Distance = 5
FollowModule.Connection = nil
FollowModule.BP = nil
FollowModule.BG = nil
FollowModule.OrigCollide = {}

function FollowModule.Start(playerName)
    if FollowModule.Active then FollowModule.Stop() end

    -- Find target
    local target = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (p.Name == playerName or string.lower(p.Name):find(string.lower(playerName))) then
            target = p
            break
        end
    end

    if not target then Notify("Follow", "Player not found: " .. playerName, "❌", 3); return end
    if not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
        Notify("Follow", target.Name .. " has no character", "❌", 2); return
    end

    local char, hum, root = GetCharacter()
    if not char then return end

    FollowModule.Active = true
    FollowModule.Target = target

    if FollowModule.Mode == "Follow" then
        -- Use CFrame teleport approach (much more reliable than BodyVelocity)
        FollowModule.Connection = RunService.Heartbeat:Connect(function()
            if not FollowModule.Active or not FollowModule.Target then return end
            local tp = FollowModule.Target
            if not tp.Parent or not tp.Character or not tp.Character:FindFirstChild("HumanoidRootPart") then
                FollowModule.Stop()
                return
            end
            local c, h, r = GetCharacter()
            if not c then return end

            local tRoot = tp.Character.HumanoidRootPart
            local dist = (r.Position - tRoot.Position).Magnitude

            if dist > FollowModule.Distance + 1 then
                local dir = (tRoot.Position - r.Position).Unit
                local targetPos = tRoot.Position - dir * FollowModule.Distance
                r.CFrame = CFrame.new(targetPos, tRoot.Position)
            end
        end)
    else
        -- Backpack / Head modes: disable collision, use BodyPosition
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                FollowModule.OrigCollide[p] = p.CanCollide
                p.CanCollide = false
            end
        end

        hum.PlatformStand = true

        FollowModule.BP = Instance.new("BodyPosition")
        FollowModule.BP.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        FollowModule.BP.P = 10000
        FollowModule.BP.D = 1000
        FollowModule.BP.Parent = root

        FollowModule.BG = Instance.new("BodyGyro")
        FollowModule.BG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        FollowModule.BG.P = 10000
        FollowModule.BG.Parent = root

        FollowModule.Connection = RunService.Heartbeat:Connect(function()
            if not FollowModule.Active or not FollowModule.Target then return end
            local tp = FollowModule.Target
            if not tp.Parent or not tp.Character or not tp.Character:FindFirstChild("HumanoidRootPart") then
                FollowModule.Stop()
                return
            end

            local tRoot = tp.Character.HumanoidRootPart
            local offset
            if FollowModule.Mode == "Backpack" then
                offset = tRoot.CFrame.LookVector * -1.5 + Vector3.new(0, 0.5, 0)
            elseif FollowModule.Mode == "Head" then
                offset = Vector3.new(0, 3, 0)
            end

            FollowModule.BP.Position = tRoot.Position + offset
            FollowModule.BG.CFrame = CFrame.new(tRoot.Position + offset, tRoot.Position + offset - tRoot.CFrame.LookVector)

            -- Keep collision off
            local c = LocalPlayer.Character
            if c then
                for _, p in ipairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end

    Notify("Follow", FollowModule.Mode .. " -> " .. target.Name, "👥", 3)
end

function FollowModule.Stop()
    FollowModule.Active = false
    FollowModule.Target = nil
    if FollowModule.Connection then FollowModule.Connection:Disconnect(); FollowModule.Connection = nil end
    if FollowModule.BP then FollowModule.BP:Destroy(); FollowModule.BP = nil end
    if FollowModule.BG then FollowModule.BG:Destroy(); FollowModule.BG = nil end

    local char, hum, root = GetCharacter()
    if hum then
        hum.PlatformStand = false
        hum.Sit = false
    end
    for part, val in pairs(FollowModule.OrigCollide) do
        if part and part.Parent then part.CanCollide = val end
    end
    FollowModule.OrigCollide = {}
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom

    Notify("Follow", "Stopped", "👥", 2)
end

