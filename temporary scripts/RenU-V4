local ESPModule = {}
ESPModule.Enabled = false
ESPModule.Objects = {}
ESPModule.Connections = {}
ESPModule.ShowHealth = true
ESPModule.ShowDistance = true
ESPModule.ShowName = true
ESPModule.FillTransparency = 0.7
ESPModule.OutlineColor = Color3.fromRGB(255, 255, 255)
ESPModule.FillColor = Color3.fromRGB(255, 50, 50)

function ESPModule.CreateESP(player)
    if player == LocalPlayer then return end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    ESPModule.RemoveESP(player)

    local char = player.Character
    local hrp = char.HumanoidRootPart
    local head = char:FindFirstChild("Head")

    local highlight = Instance.new("Highlight")
    highlight.Parent = char
    highlight.FillColor = ESPModule.FillColor
    highlight.OutlineColor = ESPModule.OutlineColor
    highlight.FillTransparency = ESPModule.FillTransparency
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = char

    local bb = Instance.new("BillboardGui")
    bb.Parent = head or hrp
    bb.Size = UDim2.new(0, 100, 0, 70)
    bb.StudsOffset = Vector3.new(0, 4, 0)
    bb.AlwaysOnTop = true
    bb.LightInfluence = 0

    local frame = Instance.new("Frame")
    frame.Parent = bb
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.8
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = frame
    nameLabel.Size = UDim2.new(1, 0, 0.35, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0.3
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold

    local hpBG = Instance.new("Frame")
    hpBG.Parent = frame
    hpBG.Size = UDim2.new(0.9, 0, 0.12, 0)
    hpBG.Position = UDim2.new(0.05, 0, 0.4, 0)
    hpBG.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    hpBG.BorderSizePixel = 0
    Instance.new("UICorner", hpBG).CornerRadius = UDim.new(0, 2)

    local hpFill = Instance.new("Frame")
    hpFill.Parent = hpBG
    hpFill.Size = UDim2.new(1, 0, 1, 0)
    hpFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    hpFill.BorderSizePixel = 0
    Instance.new("UICorner", hpFill).CornerRadius = UDim.new(0, 2)

    local hpLabel = Instance.new("TextLabel")
    hpLabel.Parent = frame
    hpLabel.Size = UDim2.new(1, 0, 0.25, 0)
    hpLabel.Position = UDim2.new(0, 0, 0.55, 0)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    hpLabel.TextStrokeTransparency = 0.3
    hpLabel.TextScaled = true
    hpLabel.Font = Enum.Font.Gotham

    local distLabel = Instance.new("TextLabel")
    distLabel.Parent = frame
    distLabel.Size = UDim2.new(1, 0, 0.2, 0)
    distLabel.Position = UDim2.new(0, 0, 0.8, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLabel.TextStrokeTransparency = 0.3
    distLabel.TextScaled = true
    distLabel.Font = Enum.Font.Gotham

    local hum = char:FindFirstChild("Humanoid")
    local hpConn = nil
    if hum then
        hpConn = hum:GetPropertyChangedSignal("Health"):Connect(function()
            local hp = math.floor(hum.Health)
            local max = math.floor(hum.MaxHealth)
            local pct = hum.Health / hum.MaxHealth
            hpLabel.Text = ESPModule.ShowHealth and (hp .. "/" .. max) or ""
            hpFill.Size = UDim2.new(pct, 0, 1, 0)
            hpBG.Visible = ESPModule.ShowHealth
            hpFill.BackgroundColor3 = pct > 0.6 and Color3.fromRGB(0, 255, 0) or pct > 0.3 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)
        end)
    end

    local alive = true
    task.spawn(function()
        while alive and ESPModule.Enabled and ESPModule.Objects[player] do
            pcall(function()
                if hum then
                    local hp = math.floor(hum.Health)
                    local max = math.floor(hum.MaxHealth)
                    local pct = max > 0 and (hum.Health / max) or 0
                    hpLabel.Text = ESPModule.ShowHealth and (hp .. "/" .. max) or ""
                    hpFill.Size = UDim2.new(pct, 0, 1, 0)
                    hpBG.Visible = ESPModule.ShowHealth
                    hpFill.BackgroundColor3 = pct > 0.6 and Color3.fromRGB(0, 255, 0) or pct > 0.3 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)
                end
                if ESPModule.ShowDistance and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local d = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
                    distLabel.Text = d .. "m"
                else
                    distLabel.Text = ""
                end
                nameLabel.Visible = ESPModule.ShowName
            end)
            task.wait(0.5)
        end
    end)

    ESPModule.Objects[player] = {
        highlight = highlight,
        billboard = bb,
        hpConnection = hpConn,
        alive = function() alive = false end
    }
end

function ESPModule.RemoveESP(player)
    local obj = ESPModule.Objects[player]
    if obj then
        if obj.alive then obj.alive() end
        if obj.highlight then pcall(function() obj.highlight:Destroy() end) end
        if obj.billboard then pcall(function() obj.billboard:Destroy() end) end
        if obj.hpConnection then pcall(function() obj.hpConnection:Disconnect() end) end
        ESPModule.Objects[player] = nil
    end
end

function ESPModule.Enable()
    if ESPModule.Enabled then return end
    ESPModule.Enabled = true

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            task.spawn(function() ESPModule.CreateESP(p) end)
        end
    end

    ESPModule.Connections.Added = SafeConnect(Players.PlayerAdded, function(p)
        if not ESPModule.Enabled or p == LocalPlayer then return end
        local conn = p.CharacterAdded:Connect(function()
            task.wait(1)
            if ESPModule.Enabled then ESPModule.CreateESP(p) end
        end)
        ESPModule.Connections[p.Name .. "_ca"] = conn
    end)

    ESPModule.Connections.Removing = SafeConnect(Players.PlayerRemoving, function(p)
        ESPModule.RemoveESP(p)
    end)

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            ESPModule.Connections[p.Name .. "_ca"] = p.CharacterAdded:Connect(function()
                task.wait(1)
                if ESPModule.Enabled then ESPModule.CreateESP(p) end
            end)
            ESPModule.Connections[p.Name .. "_cr"] = p.CharacterRemoving:Connect(function()
                ESPModule.RemoveESP(p)
            end)
        end
    end

    Notify("ESP", "Enabled", "👁️", 2)
end

function ESPModule.Disable()
    if not ESPModule.Enabled then return end
    ESPModule.Enabled = false
    for p, _ in pairs(ESPModule.Objects) do ESPModule.RemoveESP(p) end
    for _, c in pairs(ESPModule.Connections) do pcall(function() c:Disconnect() end) end
    ESPModule.Connections = {}
    Notify("ESP", "Disabled", "👁️", 2)
end

